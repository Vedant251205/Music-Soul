# ── Timbre LLM persona generator ──
# Copy these into Vercel → Project → Settings → Environment Variables.
# For local testing with `vercel dev`, copy this file to `.env.local`.

# Which provider to use: "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# Provide the key for the provider you chose (only one is needed):
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Optional model overrides:
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
